#=== FUNCTION ==================================================================
#        NAME: action_trash
# DESCRIPTION: action to move script to trash
#===============================================================================
function action_trash() {
    [ ! "$script_name" ] && { echo -e "  ERROR: no script selected\n"; return 1; }
	[ "${script_cat^^}" = "TRASH" ] && { echo -e "  ERROR: script already in trash\n"; return 1; }

	local sp="${repository_path}/.TRASH/${script_name}"
	[ -d "${sp}" ] && { echo -e "  ERROR: already exists script ${S_B}${script_name}${S_R} in trash\n"; return 1; }

    read -r -p "  Sure? Script will be move to trash (N/y) " r
    if [ "${r,,}" = "y" ]; then
        echo -e "  Moving to trash script ${S_B}${script_path}${S_R}"
		[ ! -d "${repository_path}/.TRASH/" ] && { mkdir -p "${repository_path}/.TRASH/" || return 1; }
		mv "${script_path}" "${sp}" || return 1
		echo TRASH > "${sp}/category"
		touch "${sp}/disable"

	    script_cat="TRASH"
	    script_path="${sp}"
    fi
    echo
}


#=== FUNCTION ==================================================================
#        NAME: action_untrash
