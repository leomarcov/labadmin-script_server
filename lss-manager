    [ ! "$script_name" ] && { echo -e "  ERROR: no script selected\n"; return 1; }
	[ "${script_cat^^}" != "TRASH" ] && { echo -e "  ERROR: script are not in trash\n"; return 1; }

	local sp="${repository_path}/${script_name}/"
    [ -d "${sp}" ] && { echo -e "  ERROR: already exists script ${S_B}${script_name}${S_R}\n"; return 1; }

    read -r -p "  Sure? Script will be restore from trash (N/y) " r
    if [ "${r,,}" = "y" ]; then
        echo -e "  Restoring from trash script ${S_B}${f}${S_R}"
		mv "${script_path}" "${sp}" || return 1
        echo "UNTRASH" > "${sp}/category"

		script_cat="UNTRASH"
	    script_path="${sp}"
    fi
    echo
}


