	local sp="${repository_path}/${s}"
	[ -e "${sp}" ] && { echo -e "  ERROR: script $s already exists\n"; return 1; }

	read -r -p "  Category: " c
	c=$(echo "${c^^}" | awk '{print $1}')
	[[ "${c,,}" = @(trash|untrash) ]] && { echo "  ERROR: reserved category\n"; return 1; }

