#=== FUNCTION ==================================================================
#        NAME: action_set-name
# DESCRIPTION: action to set name of selected script
#===============================================================================
function action_set-name() {
	[ ! "$script_name" ] && { echo -e "  ERROR: no script selected\n"; return 1; }
	local sd
	[ "$action_params" ] && sd="$action_params" || read -r -p "  New name: " sd
	local sn="${script_name%% *} ${sd}"
	local sp="$(dirname "${script_path}")/${sn}"

	[ -e "${sp}" ] && { echo -e "  ERROR: already exist script ${S_B}${sp}${S_R}"; return 1; }
	echo -e "  Renaming script to ${S_B}${sp}${S_R}"
	mv "${script_path}" "${sp}" || return 1
	echo

	script_name="${sn}"
	script_path="${sp}"
}


#=== FUNCTION ==================================================================
#        NAME: action_set-RE
# DESCRIPTION: action to set REGEX of selected script
#===============================================================================
function action_set-RE() {
	[ ! "$script_name" ] && { echo -e "  ERROR: no script selected\n"; return 1; }
	local sre
	[ "$action_params" ] && sre="$action_params" || read -r -p "  New REGEX: " sre
	local sn="${sre} ${script_name#* }"
	local sp="$(dirname "${script_path}")/${sn}"

	[ -e "${sp}" ] && { echo -e "  ERROR: already exist script ${S_B}${sp}${S_R}"; return 1; }
	echo -e "  Renaming script to ${S_B}${sp}${S_R}"
	mv "${script_path}" "${sp}" || return 1
	echo

	script_name="${sn}"
	script_path="${sp}"
}


#=== FUNCTION ==================================================================
#        NAME: action_set-category
# DESCRIPTION: action to set category of selected script
#===============================================================================
function action_set-category() {
	[ ! "$script_name" ] && { echo -e "  ERROR: no script selected\n"; return 1; }
	[ "${script_cat^^}" = "TRASH" ] && { echo -e "  ERROR: cant set category from trash scripts\n"; return 1; }

	local sc
	[ "$action_params" ] && sc="$action_params" || read -r -p "  New category: " sc
	[[ "${sc^^}" = @(TRASH|UNTRASH) ]] && { echo -e "  ERROR: reserved category\n"; return 1; }

	sc=$(echo "${sc^^}" | awk '{print $1}')

	local f="${script_path}/category"
	echo -e "  Setting category ${S_B}${sc}${S_R} to ${S_B}${f}${S_R}"
	echo "$sc" > "${f}"
	echo

	script_cat="$sc"
}


