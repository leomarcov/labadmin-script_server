#=== FUNCTION ==================================================================
#        NAME: help
# DESCRIPTION: Print help and exit 
#  PARAMETERS:
#	$1	Exit code value
#===============================================================================
function help() {
	echo -e "Usage: $(basename "$0") [repository]"
	exit "$1"
}


#=== FUNCTION ==================================================================
#        NAME: main
# DESCRIPTION: main
#===============================================================================
function main()  {
    # FORCE lss-admin USER                                                                                
    if [ ! $(id -un) = "lss-admin" ]; then
        if [ $(id -u) -eq 0 ]; then
            exec runuser -u lss-admin -- "$0" "$@"
        else
            echo "ERROR: lss-manager must be executed has lss-admin user"
            exit 1
        fi
    fi

	local r="linux"	# Default repository linux
	local p="$1"

	case "$p" in
		-h)	help 1		;;
		"") r="linux"	;;
		*)	r="$1"		;;
	esac

	# SET REPOSITORY
	change_repository "$r" || { echo "Invalid repository"; exit 1; }

	# MAIN LOOP
	while true; do
		read_action
		exec_action
	done
}
main "$@"
