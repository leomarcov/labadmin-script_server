#=== FUNCTION ==================================================================
#        NAME: show_header
# DESCRIPTION: show header and cleaer screen
#===============================================================================
function show_header() {
	header_width=120; [ "$COLUMNS" -lt 120 ] && header_width=$(($COLUMNS-4))
	echo -e "${C_LN} ┌$(seq -s "─" 1 $header_width | tr -d [0-9])┐"
	echo -e " │$(seq -s " " 1 $(((header_width-22)/2)) | tr -d [0-9])${C_D}${S_B}LABADMIN SCRIPT SERVER${S_R}${C_LN}$(seq -s " " 1 $(((header_width-22)/2)) | tr -d [0-9]) │"
	echo -e " └$(seq -s "─" 1 $header_width | tr -d [0-9])┘${C_D}"
}



#=== FUNCTION ==================================================================
#        NAME: show_menu
# DESCRIPTION: show list of current repository scripts and log statics
# GLOBAL VARIABLES MODIFIED
#	$scripts[]
#===============================================================================
function show_menu() {
	local f_filter f_trash								# filter flag, trash flag
	local filter="$1"									# optional filter list
	[ "${filter}" ] && f_filter="true"
	[ "${filter,,}" = "trash" ] && f_trash="true"		# flag to show trashed scripts on list

	cursor_hide
	echo -en "\n  ${C_LN}Updating scripts info...${C_D}"
	menu="  ${S_B}\tCATEGORY\tRE\tSCRIPT\tFLAG\tSELECT\tGET\tOK\tERROR\tLAST${S_R}\n"

	# Create sloc variable with script list orderer by category
	sloc=""
	for s in "${repository_path}"/*/log "${repository_path}"/.TRASH/*/log; do
		s="${s%/log}"
		[ ! "$f_trash" ] && [[ "${s%/*}" = */.TRASH ]] && continue		# Skip /.TRASH scripts if no flag trash
		unset c
		[ -e "${s}/category" ] && c=$(cat "${s}/category"); [ ! "$c" ] && c="none"
		[ -f "${s}/disable" ] && d="A" || d="Z"							# Order disabled scripts first in his category
		[[ "${c^^}" = @("LABADMIN"|"LSS") ]] && c="000"					# Order LABADMIN category first
		[ "${c}" = "none" ] && c="ZZY"									# Order no category last
		[ "${c^^}" = "TRASH" ] && c="ZZZ"								# Order trash scripts last
		sloc="${sloc}${sloc:+\n}${c}\t${d}\t${s}"
	done
	sloc=$(echo -e "$sloc" | sort -k1,1 -k2,2 -k3,3)
	clc=$(echo "$sloc" | cut -f1 | uniq -c | awk '{print $1}')
	sloc=$(echo "$sloc" | cut -f3-)

	# Create menu variable with script list
	i=0; unset scripts
	while read s; do
		local sp="${s}"
		s=$(basename "$s")
		i=$((i+1))
		scripts[$i]="$s"		# Update scripts[]

		unset sc
		[ -e "${sp}/category" ] && sc=$(cat "${sp}/category"); [ ! "$sc" ] && sc="${C_N}none${S_R}"
		scripts_cat[$i]="${sc}"
		[ "$f_filter" ] && [[ "${sc,,}" != *"$filter"* ]] && continue
		local f=" " ci="${C_D}" cl="${C_D}"
		[ -e "${sp}/disable" ] && { ci="${C_R}"; cl="${C_LN}"; }							# Colors when disabled index and line
		[ -e "${sp}"/disable ] && f="${f}${C_R}D${cl}"										# Flag disabled
		[ -e "${sp}"/priority ] && f="${f}${C_LB}P${cl}"									# Flag priority
		[ -e "${sp}"/first ] && f="${f}${C_LG}F${cl}"										# Flag first
		[ -e "${sp}"/nosavelog ] && f="${f}${C_Y}L${cl}"									# Flag nosavelog
		[ "$s" = "${script_name}" ] && cc=">${S_B}" || cc=" "										# Colors when selected script

		local st=$(grep "readonly select_type" "${sp}"/select | cut -f2 -d\")				# Select type script (once, always, custom)
		local l="$(grep -o -F -e " [GET] " -e " [EXEC_OK] " -e " [EXEC_ERROR] " "${sp}"/log | sort | uniq -c)"
		local ng=$(echo "$l" | grep -F "[GET]" | awk '{print $1}');			[ ! "$ng" ] && ng=0												# get count
		local no=$(echo "$l" | grep -F "[EXEC_OK]" | awk '{print $1}');		[ ! "$no" ] && no=0												# ok count
		local ne=$(echo "$l" | grep -F "[EXEC_ERROR]" | awk '{print $1}');  [ ! "$ne" ] && ne=0; [ "$ne" -gt 0 ] && ne="${C_R}${ne}"		# error count
		local t=$(tail -1 "${sp}"/log  | cut -f1 -d" " | tr -d "][" | tr "_" " ")													# last log time
		if [ ! "$t" ]; then t="\e[38;5;241m-"
		else t=$(($(date +%s)-$(date -d "$t" +%s))); local td="$((t/86400))" th="$(((t%86400)/3600))" tm="$(((t%3600)/60))"
		[ "$td" -gt 0 ] && t="\e[38;5;241m${td}d" || { [ "$th" -gt 0 ] && t="\e[38;5;245m${th}h" || t="\e[38;5;249m${tm}m"; }; fi
		menu="$menu\n ${cc}${ci}[$i]${C_D}${cl}\t${sc}\t${s/ /$'\t'}\t${f}\t${st}\t${ng}${lg}\t${no}$lo\t${ne}${S_R}${C_D}\t${C_LN}${t}"
	done <<< "$sloc"

	echo -en "\n\e[2A                                           "	# Overwrite Updating scripts info... line
	menu=$(echo -e "${menu}" | column -t -s $'\t' -R 6,7,8,9)

	# Add header and footer separator lines
	local bar="  $(echo -e "${C_LN}")$(seq -s"─" 1 $(($(echo "$menu" | head -1 | wc -c)-8)) | tr -d "[0-9]")$(echo -e "${C_D}")"
	menu=$(echo "${menu}" | sed "2i\\${bar}")$'\n'"${bar}"	# Add bars after format columns
	# Add category separator lines
	if [ ! "$f_filter" ]; then
		local bar2="$(echo -e "${S_D}")      $(echo -e "${C_LN}")$(seq -s"-" 1 $(($(echo "$menu" | head -1 | wc -c)-14)) | tr -d "[0-9]")$(echo -e "${C_D}")$(echo -e "${S_R}")"
		n=0
		for cl in $(echo "$clc" | head -n -1); do
			[ "$n" -eq 0 ] && n="$cl" || n=$((n+cl+1))
			menu=$(echo "$menu"| sed "$((n+3))i\\${bar2}")
		done
	fi

	menu="\n${menu}\n"

	echo -e "$menu"
	cursor_show
}


#=== FUNCTION ==================================================================
#        NAME: change_repository
# DESCRIPTION: change current repository and show menu
# PARAMETERS
#	$1		repository name
#
# GLOBAL VARIABLES MODIFIED
#	$repository
#	$repository_path
#	$script_name
#	$scripts
#
# RETURN
#	0 if repository change is ok
#	1 if cant change repository (not exists?)
#===============================================================================
function change_repository() {
	local r="$1"

	# Check if exist repository
	[ ! -d "${repositories_path}/${r}" ] && return 1
	[[ $(readlink -f "${repositories_path}/${r}") = $(readlink -f "${repositories_path}") ]] && return 1		# Check if try directory outside repositories_path
	[[ $(readlink -f "${repositories_path}/${r}") != $(readlink -f "${repositories_path}")* ]] && return 1		# Check if try directory outside repositories_path

	([ ! "$repository" ] || [ "$repository" != "$r" ]) && clear
	show_header
	repository="$r"
	repository_path="${repositories_path}/${repository}/"
	unset script_name
	unset script_cat
	unset script_path
	unset scripts

	show_menu
	return 0
}


#=== FUNCTION ==================================================================
#        NAME: read_action
# DESCRIPTION: prompt for action to exec and change repository
# GLOBAL VARIABLES MODIFIED
#	$action
#	$action_params
#===============================================================================
function read_action() {
	# Generate actions files for read tab autocomplete
	if [ ! "$menu_path" ]; then
	   menu_path=$(mktemp -d)
	   mkdir "${menu_path}/script" "${menu_path}/root"
	   cd "${menu_path}/root/"; touch cd create help list
	   cd "${menu_path}/script/"; touch bash  delete  set-name  set-RE  set-category  disable  enable  priority  first  nosavelog log  status  map  log-clean  log-wipe  ls  script  select trash untrash
	fi
	cd "${menu_path}/$([ "$script_name" ] && echo "script" || echo "root")"

	# Read prompt: repository/script selected>
	local prompt="  ${C_Y}${repository}${C_D}$([ "$script_name" ] && echo "/${C_Y}${script_name}${C_D}")> "
	read -r -e  -p "$(echo -e "$prompt")" action

	action="$(echo "$action" | xargs)"		# Trim and compact spaces
	action_params="${action#* }"
	[ "$action_params" = "$action" ] && action_params=""
	action="${action%% *}"

	# Empty action: list
	if [ ! "$action" ]; then
		action="list"

	# Action <n>: cd <n>
	elif [ "$action" -eq "$action" ] &>/dev/null; then
		action_params="$action"
		action="cd"

	# Action repository name
	elif change_repository "$action"; then
		action="none"
	fi
}


#=== FUNCTION ==================================================================
#        NAME: action_none
# DESCRIPTION: empty action (do nothing and show menu again)
#===============================================================================

function action_none() {
	return
}



#=== FUNCTION ==================================================================
#        NAME: action_cd
# DESCRIPTION: change selected script according $action and $actions_params
#				cd | cd .. 	unselect current script
#				cd <n>		select <n> script
#				cd <str>	select string contaning <str> in name
#
# GLOBAL VARIABLES MODIFIED
#   $action
#   $action_params
#===============================================================================
function action_cd() {
		# cd parent
        if [ ! "$action_params" ] || [ "$action_params" = ".." ]; then
            action_..

		# cd <n>
		elif [ "$action_params" -eq "$action_params" ] &>/dev/null; then
            script_name="${scripts[$action_params]}"
            [ ! "$script_name" ] && echo -e "  ERROR: invalid script number\n"
			script_cat="${scripts_cat[$action_params]}"

		# cd <string>
		else
            local l=""
            l=$(for i in ${!scripts[@]}; do
				echo "${scripts[$i]}" | grep -Fiq "$action_params" && echo "$i"
            done)
            if [ $(echo "$l" | wc -l) -gt 1 ]; then
				IFS=$'\n'
				for i in $l; do
					echo "   ${scripts[$i]}"
    			done
				IFS=$'\n\t '
				echo
            elif [ "$l" ]; then
                script_name="${scripts[$l]}"
                script_cat="${scripts_cat[$l]}"
            else
                echo "  ERROR: script not found $action_params\n"
            fi
        fi

		if [ "${script_cat^^}" = "TRASH" ]; then
			script_path="${repository_path}/.TRASH/${script_name}"
		else
			script_path="${repository_path}/${script_name}"
		fi
}



#=== FUNCTION ==================================================================
#        NAME: exec_action
# DESCRIPTION: exec function of selected action
#===============================================================================
function exec_action() {
	action_function="action_${action}"
	if [ "$(type -t "$action_function")" != "function" ]; then
		echo -e "  Unrecognized action: $action\n"
		return 1
	fi
	"$action_function"
}


